{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://measurex.local/schemas/agent-ops-scenario.json",
  "title": "MeasureX agent operations adversarial scenario",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "request", "setup", "expected_outcome", "expected_deterministic_invariants"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "request": { "type": "string", "minLength": 1 },
    "setup": { "type": "object" },
    "expected_outcome": { "type": "string", "minLength": 1 },
    "expected_deterministic_invariants": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
